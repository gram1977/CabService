# Frontend .env file
# Frontend is static
# Variables injected during build process
# No runtime access: Unlike Node.js, the browser doesn’t have a process.env. Once the app is built, 
# you can’t change those variables without rebuilding, because the values are baked into the 
# static files
# in React, remember: it’s not dynamic at runtime. It’s baked in during the build step.
REACT_APP_API_PORT=3000
