# Frontend .env file
# Frontend is static
# Variables injected during build process
# No runtime access: Unlike Node.js, the browser doesn’t have a process.env. Once the app is built, 
# you can’t change those variables without rebuilding, because the values are baked into the 
# static files
# in React, remember: it’s not dynamic at runtime. It’s baked in during the build step.
#REACT_APP_API_PORT=3000

#Frontend point to localhost backend during development. When deployed, it should point to the actual backend URL.
#REACT_APP_API_URL=http://localhost:3000

#For Deploying Cabservice frontend React App on AWS, React frontend .env file variable REACT_APP_API_URL must point to 
#AWS Elastic Beanstalk URL where backend is deployed.
REACT_APP_API_URL=https://cabservice-dev.eba-kbqdsvuj.eu-north-1.elasticbeanstalk.com/